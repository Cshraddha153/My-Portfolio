# Port the API server listens on
PORT=5000

# Comma-separated list of allowed origins for CORS (optional).
# Leave empty to allow all origins during development.
CORS_ORIGIN=

# ---------------------------------------------------------------------------
# Email delivery for the contact form (optional but recommended)
# ---------------------------------------------------------------------------
# Where contact-form submissions are delivered.
MAIL_TO=shraddha76830@gmail.com

# SMTP settings. For Gmail:
#   1. Enable 2-Step Verification on your Google account.
#   2. Create an "App password": https://myaccount.google.com/apppasswords
#   3. Use that 16-character app password as SMTP_PASS (NOT your normal password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=shraddha76830@gmail.com
SMTP_PASS=your_16_char_app_password_here
